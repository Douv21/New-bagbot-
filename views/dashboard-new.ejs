<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Discord Bot</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="/css/dashboard.css" rel="stylesheet">
</head>
<body class="bg-gray-900 text-white">
    <!-- Sidebar -->
    <aside id="sidebar" class="fixed left-0 top-0 h-full w-64 bg-gray-800 transform transition-transform duration-300 z-40">
        <div class="p-4">
            <div class="flex items-center justify-between mb-8">
                <div class="flex items-center">
                    <i class="fab fa-discord text-3xl text-indigo-500 mr-3"></i>
                    <span class="text-xl font-bold">Dashboard</span>
                </div>
                <button id="sidebarToggle" class="lg:hidden text-gray-400 hover:text-white">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <!-- Navigation -->
            <nav class="space-y-2">
                <a href="#overview" class="nav-item flex items-center p-3 rounded-lg hover:bg-gray-700 transition">
                    <i class="fas fa-home w-5 mr-3"></i>
                    <span>Accueil</span>
                </a>
                <a href="#servers" class="nav-item flex items-center p-3 rounded-lg hover:bg-gray-700 transition">
                    <i class="fas fa-server w-5 mr-3"></i>
                    <span>Serveurs</span>
                </a>
                <a href="#welcome" class="nav-item flex items-center p-3 rounded-lg hover:bg-gray-700 transition">
                    <i class="fas fa-door-open w-5 mr-3"></i>
                    <span>Arrivée/Départ</span>
                </a>
                <a href="#shop" class="nav-item flex items-center p-3 rounded-lg hover:bg-gray-700 transition">
                    <i class="fas fa-shopping-cart w-5 mr-3"></i>
                    <span>Boutique</span>
                </a>
                <a href="#moderation" class="nav-item flex items-center p-3 rounded-lg hover:bg-gray-700 transition">
                    <i class="fas fa-shield-alt w-5 mr-3"></i>
                    <span>Modération</span>
                </a>
                <a href="#confessions" class="nav-item flex items-center p-3 rounded-lg hover:bg-gray-700 transition">
                    <i class="fas fa-comment-secret w-5 mr-3"></i>
                    <span>Confessions</span>
                </a>
                <a href="#autothreads" class="nav-item flex items-center p-3 rounded-lg hover:bg-gray-700 transition">
                    <i class="fas fa-comments w-5 mr-3"></i>
                    <span>Auto-Threads</span>
                </a>
                <a href="#settings" class="nav-item flex items-center p-3 rounded-lg hover:bg-gray-700 transition">
                    <i class="fas fa-cog w-5 mr-3"></i>
                    <span>Paramètres</span>
                </a>
            </nav>

            <!-- User Profile -->
            <div class="absolute bottom-4 left-4 right-4">
                <div class="bg-gray-700 rounded-lg p-3">
                    <div class="flex items-center">
                        <img src="<%= user.avatar ? `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png` : 'https://cdn.discordapp.com/embed/avatars/0.png' %>" 
                             alt="Avatar" class="w-10 h-10 rounded-full mr-3">
                        <div class="flex-1">
                            <div class="font-semibold text-sm"><%= user.username %></div>
                            <div class="text-xs text-gray-400">Admin</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main id="mainContent" class="transition-all duration-300">
        <!-- Top Navigation -->
        <header class="bg-gray-800 shadow-lg">
            <div class="px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between h-16">
                    <div class="flex items-center">
                        <button id="mobileSidebarToggle" class="lg:hidden text-gray-400 hover:text-white mr-4">
                            <i class="fas fa-bars"></i>
                        </button>
                        <h1 class="text-xl font-semibold">Dashboard Bot</h1>
                    </div>
                    <div class="flex items-center space-x-4">
                        <div class="hidden sm:flex items-center">
                            <span class="text-sm text-gray-400">Statut:</span>
                            <span class="ml-2 flex items-center">
                                <span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>
                                En ligne
                            </span>
                        </div>
                        <a href="/logout" class="bg-red-600 hover:bg-red-700 px-3 py-1 rounded text-sm">
                            Déconnexion
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <div class="p-4 sm:p-6 lg:p-8">
            <!-- Overview Section -->
            <section id="overview" class="content-section">
                <h2 class="text-2xl font-bold mb-6">Vue d'ensemble</h2>
                
                <!-- Stats Cards -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                    <div class="bg-gray-800 rounded-lg p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-400 text-sm">Serveurs</p>
                                <p class="text-2xl font-bold"><%= guilds ? guilds.length : 0 %></p>
                            </div>
                            <i class="fas fa-server text-3xl text-indigo-500"></i>
                        </div>
                    </div>
                    <div class="bg-gray-800 rounded-lg p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-400 text-sm">Commandes</p>
                                <p class="text-2xl font-bold">12</p>
                            </div>
                            <i class="fas fa-terminal text-3xl text-green-500"></i>
                        </div>
                    </div>
                    <div class="bg-gray-800 rounded-lg p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-400 text-sm">Uptime</p>
                                <p class="text-2xl font-bold">24h</p>
                            </div>
                            <i class="fas fa-clock text-3xl text-yellow-500"></i>
                        </div>
                    </div>
                    <div class="bg-gray-800 rounded-lg p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-400 text-sm">Latence</p>
                                <p class="text-2xl font-bold">45ms</p>
                            </div>
                            <i class="fas fa-wifi text-3xl text-blue-500"></i>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="bg-gray-800 rounded-lg p-6">
                    <h3 class="text-lg font-semibold mb-4">Actions rapides</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                        <button class="bg-indigo-600 hover:bg-indigo-700 p-4 rounded-lg text-center transition">
                            <i class="fas fa-plus-circle text-2xl mb-2"></i>
                            <p>Ajouter un serveur</p>
                        </button>
                        <button class="bg-green-600 hover:bg-green-700 p-4 rounded-lg text-center transition">
                            <i class="fas fa-cog text-2xl mb-2"></i>
                            <p>Configurer le bot</p>
                        </button>
                        <button class="bg-purple-600 hover:bg-purple-700 p-4 rounded-lg text-center transition">
                            <i class="fas fa-chart-line text-2xl mb-2"></i>
                            <p>Voir les statistiques</p>
                        </button>
                    </div>
                </div>
            </section>

            <!-- Servers Section -->
            <section id="servers" class="content-section hidden">
                <h2 class="text-2xl font-bold mb-6">Serveurs</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% if (guilds && guilds.length > 0) { %>
                        <% guilds.forEach(guild => { %>
                            <div class="bg-gray-800 rounded-lg p-6 hover:bg-gray-750 transition">
                                <div class="flex items-center mb-4">
                                    <% if (guild.icon) { %>
                                        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" 
                                             alt="<%= guild.name %>" class="w-12 h-12 rounded-full mr-3">
                                    <% } else { %>
                                        <div class="w-12 h-12 rounded-full bg-indigo-600 flex items-center justify-center mr-3">
                                            <i class="fas fa-server"></i>
                                        </div>
                                    <% } %>
                                    <div>
                                        <h3 class="font-semibold"><%= guild.name %></h3>
                                        <p class="text-sm text-gray-400">
                                            <% if (guild.owner) { %>
                                                <i class="fas fa-crown text-yellow-500 mr-1"></i>Propriétaire
                                            <% } else { %>
                                                Membre
                                            <% } %>
                                        </p>
                                    </div>
                                </div>
                                <div class="space-y-2">
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-400">Membres:</span>
                                        <span><%= guild.memberCount || 'N/A' %></span>
                                    </div>
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-400">Bot présent:</span>
                                        <span class="text-green-500">
                                            <i class="fas fa-check-circle"></i> Oui
                                        </span>
                                    </div>
                                </div>
                                <div class="mt-4 space-y-2">
                                    <button class="w-full discord-blurple hover:bg-indigo-700 px-3 py-2 rounded text-sm font-medium">
                                        <i class="fas fa-cog mr-2"></i>Gérer
                                    </button>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-span-full text-center py-12">
                            <i class="fas fa-server text-6xl text-gray-600 mb-4"></i>
                            <p class="text-gray-400">Aucun serveur trouvé</p>
                        </div>
                    <% } %>
                </div>
            </section>

            <!-- Welcome/Goodbye Section -->
            <section id="welcome" class="content-section hidden">
                <h2 class="text-2xl font-bold mb-6">Système d'arrivée/départ</h2>
                <div class="bg-gray-800 rounded-lg p-6">
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <!-- Welcome Settings -->
                        <div>
                            <h3 class="text-lg font-semibold mb-4">
                                <i class="fas fa-door-open text-green-500 mr-2"></i>
                                Message de bienvenue
                            </h3>
                            <div class="space-y-4">
                                <div class="flex items-center justify-between">
                                    <label class="text-sm">Activer les messages de bienvenue</label>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" class="sr-only peer" id="welcomeEnabled">
                                        <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                                    </label>
                                </div>
                                <div>
                                    <label class="block text-sm mb-2">Salon de bienvenue</label>
                                    <select class="w-full bg-gray-700 rounded px-3 py-2" id="welcomeChannel">
                                        <option>Sélectionner un salon...</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-sm mb-2">Message de bienvenue</label>
                                    <textarea class="w-full bg-gray-700 rounded px-3 py-2 h-24" id="welcomeMessage" placeholder="Bienvenue {user} sur le serveur !"></textarea>
                                    <p class="text-xs text-gray-400 mt-1">Variables: {user}, {server}, {count}</p>
                                </div>
                            </div>
                        </div>

                        <!-- Goodbye Settings -->
                        <div>
                            <h3 class="text-lg font-semibold mb-4">
                                <i class="fas fa-door-closed text-red-500 mr-2"></i>
                                Message d'au revoir
                            </h3>
                            <div class="space-y-4">
                                <div class="flex items-center justify-between">
                                    <label class="text-sm">Activer les messages d'au revoir</label>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" class="sr-only peer" id="goodbyeEnabled">
                                        <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                                    </label>
                                </div>
                                <div>
                                    <label class="block text-sm mb-2">Salon d'au revoir</label>
                                    <select class="w-full bg-gray-700 rounded px-3 py-2" id="goodbyeChannel">
                                        <option>Sélectionner un salon...</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-sm mb-2">Message d'au revoir</label>
                                    <textarea class="w-full bg-gray-700 rounded px-3 py-2 h-24" id="goodbyeMessage" placeholder="Au revoir {user} !"></textarea>
                                    <p class="text-xs text-gray-400 mt-1">Variables: {user}, {server}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-6">
                        <button class="bg-green-600 hover:bg-green-700 px-6 py-2 rounded-lg font-medium">
                            <i class="fas fa-save mr-2"></i>Sauvegarder
                        </button>
                    </div>
                </div>
            </section>

            <!-- Shop Section -->
            <section id="shop" class="content-section hidden">
                <h2 class="text-2xl font-bold mb-6">Boutique</h2>
                <div class="bg-gray-800 rounded-lg p-6">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-lg font-semibold">Gestion de la boutique</h3>
                        <button class="bg-indigo-600 hover:bg-indigo-700 px-4 py-2 rounded-lg text-sm">
                            <i class="fas fa-plus mr-2"></i>Ajouter un article
                        </button>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        <!-- Shop items will be loaded here -->
                        <div class="bg-gray-700 rounded-lg p-4">
                            <div class="flex justify-between items-start mb-3">
                                <h4 class="font-semibold">Rôle VIP</h4>
                                <span class="text-green-400 font-bold">1000€</span>
                            </div>
                            <p class="text-sm text-gray-400 mb-3">Accès VIP pendant 30 jours</p>
                            <div class="flex justify-between">
                                <button class="text-blue-400 hover:text-blue-300 text-sm">
                                    <i class="fas fa-edit mr-1"></i>Modifier
                                </button>
                                <button class="text-red-400 hover:text-red-300 text-sm">
                                    <i class="fas fa-trash mr-1"></i>Supprimer
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Moderation Section -->
            <section id="moderation" class="content-section hidden">
                <h2 class="text-2xl font-bold mb-6">Modération</h2>
                <div class="bg-gray-800 rounded-lg p-6">
                    <h3 class="text-lg font-semibold mb-4">Configuration de la modération</h3>
                    <div class="space-y-4">
                        <div class="flex items-center justify-between">
                            <label class="text-sm">Activer la modération automatique</label>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" class="sr-only peer">
                                <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                            </label>
                        </div>
                        <div>
                            <label class="block text-sm mb-2">Salon des logs de modération</label>
                            <select class="w-full bg-gray-700 rounded px-3 py-2">
                                <option>Sélectionner un salon...</option>
                            </select>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Confessions Section -->
            <section id="confessions" class="content-section hidden">
                <h2 class="text-2xl font-bold mb-6">Confessions</h2>
                <div class="bg-gray-800 rounded-lg p-6">
                    <h3 class="text-lg font-semibold mb-4">Système de confessions</h3>
                    <div class="space-y-4">
                        <div class="flex items-center justify-between">
                            <label class="text-sm">Activer les confessions</label>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" class="sr-only peer">
                                <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                            </label>
                        </div>
                        <div>
                            <label class="block text-sm mb-2">Salon des confessions</label>
                            <select class="w-full bg-gray-700 rounded px-3 py-2">
                                <option>Sélectionner un salon...</option>
                            </select>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Auto-Threads Section -->
            <section id="autothreads" class="content-section hidden">
                <h2 class="text-2xl font-bold mb-6">Auto-Threads</h2>
                <div class="bg-gray-800 rounded-lg p-6">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-lg font-semibold">Gestion des auto-threads</h3>
                        <button class="bg-indigo-600 hover:bg-indigo-700 px-4 py-2 rounded-lg text-sm">
                            <i class="fas fa-plus mr-2"></i>Ajouter une règle
                        </button>
                    </div>
                    
                    <div class="space-y-4">
                        <div class="bg-gray-700 rounded-lg p-4">
                            <div class="flex justify-between items-center">
                                <div>
                                    <h4 class="font-semibold">Salon général</h4>
                                    <p class="text-sm text-gray-400">Auto-thread activé pour tous les messages</p>
                                </div>
                                <div class="flex space-x-2">
                                    <button class="text-blue-400 hover:text-blue-300">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="text-red-400 hover:text-red-300">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Settings Section -->
            <section id="settings" class="content-section hidden">
                <h2 class="text-2xl font-bold mb-6">Paramètres généraux</h2>
                <div class="bg-gray-800 rounded-lg p-6">
                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm mb-2">Préfixe des commandes</label>
                            <input type="text" class="w-full bg-gray-700 rounded px-3 py-2" value="!" />
                        </div>
                        <div>
                            <label class="block text-sm mb-2">Langue du bot</label>
                            <select class="w-full bg-gray-700 rounded px-3 py-2">
                                <option>Français</option>
                                <option>English</option>
                            </select>
                        </div>
                        <div class="flex items-center justify-between">
                            <label class="text-sm">Mode maintenance</label>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" class="sr-only peer">
                                <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-red-600"></div>
                            </label>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <script src="/js/dashboard.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Discord Bot</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        .gradient-bg {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        .discord-blurple {
            background-color: #5865F2;
        }
        .discord-blurple:hover {
            background-color: #4752C4;
        }
    </style>
</head>
<body class="bg-gray-900 text-white">
    <!-- Navigation -->
    <nav class="bg-gray-800 shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <i class="fab fa-discord text-3xl text-indigo-500 mr-3"></i>
                    <span class="text-xl font-bold">Dashboard</span>
                </div>
                <div class="flex items-center space-x-4">
                    <img src="<%= user.avatar ? `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png` : 'https://cdn.discordapp.com/embed/avatars/0.png' %>" 
                         alt="Avatar" class="w-8 h-8 rounded-full">
                    <span class="text-sm"><%= user.username %>#<%= user.discriminator %></span>
                    <a href="/" class="text-gray-300 hover:text-white">
                        <i class="fas fa-home"></i>
                    </a>
                    <a href="/logout" class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded-md text-sm font-medium">
                        Déconnexion
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Dashboard Content -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- User Stats -->
        <div class="gradient-bg rounded-lg p-6 mb-8">
            <h1 class="text-2xl font-bold mb-4">Bienvenue, <%= user.username %>!</h1>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="bg-white bg-opacity-20 rounded-lg p-4">
                    <div class="text-3xl font-bold"><%= guilds ? guilds.length : 0 %></div>
                    <div class="text-sm opacity-90">Serveurs</div>
                </div>
                <div class="bg-white bg-opacity-20 rounded-lg p-4">
                    <div class="text-3xl font-bold">3</div>
                    <div class="text-sm opacity-90">Commandes</div>
                </div>
                <div class="bg-white bg-opacity-20 rounded-lg p-4">
                    <div class="text-3xl font-bold">En ligne</div>
                    <div class="text-sm opacity-90">Status Bot</div>
                </div>
            </div>
        </div>

        <!-- Servers Section -->
        <div class="mb-8">
            <h2 class="text-2xl font-bold mb-6">Vos Serveurs</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% if (guilds && guilds.length > 0) { %>
                    <% guilds.forEach(guild => { %>
                        <div class="bg-gray-800 rounded-lg p-6 hover:bg-gray-750 transition">
                            <div class="flex items-center mb-4">
                                <% if (guild.icon) { %>
                                    <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" 
                                         alt="<%= guild.name %>" class="w-12 h-12 rounded-full mr-3">
                                <% } else { %>
                                    <div class="w-12 h-12 rounded-full bg-indigo-600 flex items-center justify-center mr-3">
                                        <i class="fas fa-server"></i>
                                    </div>
                                <% } %>
                                <div>
                                    <h3 class="font-semibold"><%= guild.name %></h3>
                                    <p class="text-sm text-gray-400">
                                        <% if (guild.owner) { %>
                                            <i class="fas fa-crown text-yellow-500 mr-1"></i>Propriétaire
                                        <% } else { %>
                                            Membre
                                        <% } %>
                                    </p>
                                </div>
                            </div>
                            <div class="space-y-2">
                                <div class="flex justify-between text-sm">
                                    <span class="text-gray-400">Membres:</span>
                                    <span><%= guild.memberCount || 'N/A' %></span>
                                </div>
                                <div class="flex justify-between text-sm">
                                    <span class="text-gray-400">Bot présent:</span>
                                    <span class="text-green-500">
                                        <i class="fas fa-check-circle"></i> Oui
                                    </span>
                                </div>
                            </div>
                            <div class="mt-4 space-y-2">
                                <button class="w-full discord-blurple hover:bg-indigo-700 px-3 py-2 rounded text-sm font-medium">
                                    <i class="fas fa-cog mr-2"></i>Gérer
                                </button>
                                <% if (guild.owner) { %>
                                    <button class="w-full bg-green-600 hover:bg-green-700 px-3 py-2 rounded text-sm font-medium">
                                        <i class="fas fa-user-plus mr-2"></i>Inviter le bot
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full text-center py-12">
                        <i class="fas fa-server text-6xl text-gray-600 mb-4"></i>
                        <p class="text-gray-400">Aucun serveur trouvé</p>
                        <p class="text-sm text-gray-500 mt-2">Assurez-vous que le bot est présent sur vos serveurs</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Bot Settings -->
        <div class="bg-gray-800 rounded-lg p-6">
            <h2 class="text-xl font-bold mb-4">Paramètres du Bot</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <h3 class="font-semibold mb-3">Commandes</h3>
                    <div class="space-y-2">
                        <div class="flex items-center justify-between">
                            <span class="text-sm">/help</span>
                            <span class="text-xs bg-green-600 px-2 py-1 rounded">Actif</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-sm">/ping</span>
                            <span class="text-xs bg-green-600 px-2 py-1 rounded">Actif</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-sm">/server</span>
                            <span class="text-xs bg-green-600 px-2 py-1 rounded">Actif</span>
                        </div>
                    </div>
                </div>
                <div>
                    <h3 class="font-semibold mb-3">Statistiques</h3>
                    <div class="space-y-2">
                        <div class="flex items-center justify-between">
                            <span class="text-sm">Uptime:</span>
                            <span class="text-xs text-green-400">24h 30m</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-sm">Mémoire:</span>
                            <span class="text-xs text-blue-400">128MB</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-sm">Latence:</span>
                            <span class="text-xs text-yellow-400">45ms</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-800 py-8 mt-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <p class="text-gray-400">
                Dashboard du Bot Discord - 
                <a href="/" class="text-indigo-400 hover:text-indigo-300">Accueil</a>
            </p>
        </div>
    </footer>
</body>
</html>
